CREATE TABLE HealthRecordEntity (
    id TEXT NOT NULL PRIMARY KEY,
    category TEXT NOT NULL,
    date INTEGER NOT NULL,
    weekNumber INTEGER NOT NULL DEFAULT 0,
    weightKg REAL,
    systolicBp INTEGER,
    diastolicBp INTEGER,
    kickCount INTEGER,
    kickTimeMinutes INTEGER,
    photoUri TEXT,
    memoTitle TEXT,
    memoContent TEXT,
    createdAt INTEGER NOT NULL,
    updatedAt INTEGER NOT NULL
);
